# Render Web Service environment.
# Fill real values in Render's Environment tab, never in this file.

NODE_ENV=production
HOST=0.0.0.0

# Public app URLs. Use the Render URL first, then your custom domain after DNS is live.
APP_PUBLIC_BASE_URL=
APP_API_BASE_URL=
CORS_ORIGIN=

# Supabase values needed by the Node web service.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_FUNCTION_BASE_URL=

# Optional non-sensitive delivery limits mirrored by the local/server fallback paths.
WALLET_BUSINESS_DAILY_LIMIT=500
WALLET_CUSTOMER_DAILY_LIMIT=12
WALLET_CARD_DAILY_LIMIT=6
WALLET_GOOGLE_TEXT_AND_NOTIFY_LIMIT_PER_PASS_24H=3
WALLET_DUPLICATE_WINDOW_MINUTES=10
WALLET_PUBLIC_CLAIM_RATE_LIMIT=80
WALLET_PUBLIC_CLAIM_RATE_LIMIT_WINDOW_SECONDS=900
WALLET_RECIPIENT_PROCESSING_TIMEOUT_MINUTES=15
WALLET_QUEUE_PROCESSING_TIMEOUT_MINUTES=15
WALLET_DEFAULT_TITLE=
WALLET_DEFAULT_MESSAGE=
WALLET_ALLOWED_TARGETS=all_active,template,platform_apple,platform_google,stamp_count,streak_count,vip_level,balance_range,cloakroom_open,event,coupon_unredeemed,membership_status

# Apple, Google Wallet, payment webhook and cron secrets belong in Supabase
# Edge Function secrets for this project. See supabase/secrets.example.env.
