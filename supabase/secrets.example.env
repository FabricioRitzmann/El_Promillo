# Supabase Edge Secrets template for the direct Apple/Google Wallet path.
# Copy this file to supabase/secrets.local.env, fill real values there, and never commit it.
# Apply it with: supabase secrets set --env-file supabase/secrets.local.env
# For PEM, p8 and Google JSON values, either paste a single-line value with escaped \n
# or use the individual README commands with $(cat certs/file.pem).

SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
APP_PUBLIC_BASE_URL="https://deine-domain.ch"

APPLE_TEAM_ID="YOUR_APPLE_TEAM_ID"
APPLE_PASS_TYPE_ID="pass.com.example.walletcards"
APPLE_WWDR_CERT="PASTE_APPLE_WWDR_PEM_OR_SET_WITH_CAT"
APPLE_PASS_CERT="PASTE_APPLE_PASS_CERT_PEM_OR_SET_WITH_CAT"
APPLE_PASS_KEY="PASTE_APPLE_PASS_KEY_PEM_OR_SET_WITH_CAT"
APPLE_PASS_KEY_PASSWORD="YOUR_CERTIFICATE_PASSWORD_OR_EMPTY"
APPLE_WEB_SERVICE_BASE_URL="https://YOUR_PROJECT_REF.supabase.co/functions/v1/apple-wallet-webservice"
APPLE_APNS_KEY_ID="YOUR_APPLE_APNS_KEY_ID"
APPLE_APNS_TEAM_ID="YOUR_APPLE_TEAM_ID"
APPLE_APNS_AUTH_KEY="PASTE_APPLE_APNS_P8_OR_SET_WITH_CAT"

GOOGLE_WALLET_ISSUER_ID="YOUR_GOOGLE_WALLET_ISSUER_ID"
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON="PASTE_GOOGLE_SERVICE_ACCOUNT_JSON_OR_SET_WITH_CAT"
GOOGLE_WALLET_CLASS_SUFFIX="wallet_cards_mvp"
GOOGLE_WALLET_ORIGINS="https://deine-domain.ch"

SAMSUNG_WALLET_PARTNER_ID="YOUR_SAMSUNG_PARTNER_ID"
SAMSUNG_WALLET_PARTNER_CODE="YOUR_SAMSUNG_PARTNER_CODE_OR_PARTNER_ID"
SAMSUNG_WALLET_CARD_ID="YOUR_SAMSUNG_CARD_ID"
SAMSUNG_WALLET_CARD_TYPE="loyalty"
SAMSUNG_WALLET_CARD_SUB_TYPE="others"
SAMSUNG_WALLET_CERTIFICATE_ID="YOUR_SAMSUNG_CERTIFICATE_ID"
SAMSUNG_WALLET_COUNTRY_CODE="CH"
SAMSUNG_WALLET_ENV="sandbox"
SAMSUNG_WALLET_ADD_FLOW="data_fetch"
# Use "cdata" when the Samsung Partner Portal script guide shows cdata="${CARD DATA as JWT}".
SAMSUNG_WALLET_PRIVATE_KEY_PEM="PASTE_SAMSUNG_PRIVATE_KEY_PEM_OR_SET_WITH_CAT"
SAMSUNG_WALLET_SAMSUNG_PUBLIC_KEY_PEM="PASTE_SAMSUNG_PUBLIC_KEY_OR_CERT_PEM_OR_SET_WITH_CAT"
SAMSUNG_WALLET_RD_CLICK_URL="https://us-rd.mcsvc.samsung.com/statistics/click/addtowlt?..."
SAMSUNG_WALLET_RD_IMPRESSION_URL="https://us-rd.mcsvc.samsung.com/statistics/impression/addtowlt?..."
SAMSUNG_WALLET_PARTNER_SERVER_URL="https://YOUR_PROJECT_REF.supabase.co/functions/v1/samsung-wallet-server"
SAMSUNG_WALLET_ALLOW_UNVERIFIED_AUTH="false"

PAYMENT_PROVIDER="manual"
PAYMENT_CHECKOUT_BASE_URL=""
PAYMENT_WEBHOOK_SECRET="REPLACE_WITH_RANDOM_32_PLUS_CHARS"

WALLET_CRON_SECRET="REPLACE_WITH_RANDOM_32_PLUS_CHARS"
WALLET_BUSINESS_DAILY_LIMIT="500"
WALLET_CUSTOMER_DAILY_LIMIT="12"
WALLET_CARD_DAILY_LIMIT="6"
WALLET_GOOGLE_TEXT_AND_NOTIFY_LIMIT_PER_PASS_24H="3"
WALLET_DUPLICATE_WINDOW_MINUTES="10"
WALLET_PUBLIC_CLAIM_RATE_LIMIT="80"
WALLET_PUBLIC_CLAIM_RATE_LIMIT_WINDOW_SECONDS="900"
WALLET_RECIPIENT_PROCESSING_TIMEOUT_MINUTES="15"
WALLET_QUEUE_PROCESSING_TIMEOUT_MINUTES="15"
